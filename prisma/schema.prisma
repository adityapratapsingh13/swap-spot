datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  picture       String?
  accounts      Account[]
}

model Account {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.String
  access_token      String?  @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.String
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @db.String
  description String   @db.String
  price       Float    @db.Double
  image       String[]     // Changed from images array to single image
  category    Category
  seller      String   @db.String
  stock       Int      @db.Int
  ratings     Float    @default(0) @db.Double
  reviews     Review[] @relation("ProductReviews")
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  product   Product  @relation("ProductReviews", fields: [productId], references: [id])
  productId String   @db.ObjectId
  rating    Float    @db.Double
  comment   String   @db.String
  createdAt DateTime @default(now())
}

enum Category {
  Electronics
  fastion
  Furtinure
  Accessories
  Sports
  othres
}
